#!/bin/bash -e

# If running the rails server (with or without thrust) then create or migrate existing database
if [[ "${@}" == *"./bin/rails server"* ]] || [[ "${@: -2:1}" == "./bin/rails" && "${@: -1:1}" == "server" ]]; then
  echo "Running database migrations..."
  ./bin/rails db:prepare
fi

exec "${@}"
